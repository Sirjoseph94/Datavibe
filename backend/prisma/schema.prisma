generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  importFileExtension = "js"
}

datasource db {
  provider = "postgresql"
}

model IspBundle {
  id        Int       @id @default(autoincrement())
  network   String
  size      String
  price     Float
  createdAt DateTime? @default(now())
  updatedAt DateTime? @default(now())

  @@map("IspBundles")
}

model Request {
  id           Int       @id @default(autoincrement())
  subscriberId Int?
  phoneNumber  String
  isp          String
  dataBundle   String
  amount       Float
  reference    String?   @unique
  status       String?   @default("pending")
  treatedBy    Int?
  createdAt    DateTime? @default(now())
  updatedAt    DateTime? @default(now())
  subscriber   User?     @relation("Requests_subscriberIdToUsers", fields: [subscriberId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  treatedUser  User?     @relation("Requests_treatedByToUsers", fields: [treatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("Requests")
}

model User {
  id            Int       @id @default(autoincrement())
  username      String    @unique
  password_hash String
  role          String
  createdAt     DateTime? @default(now())
  requests      Request[] @relation("Requests_subscriberIdToUsers")
  treatments    Request[] @relation("Requests_treatedByToUsers")

  @@map("Users")
}

model PaymentGateway {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  displayName String
  isActive    Boolean   @default(true)
  isDefault   Boolean   @default(false)
  config      String?   
  createdAt   DateTime? @default(now())
  updatedAt   DateTime? @default(now())

  @@map("PaymentGateways")
}

